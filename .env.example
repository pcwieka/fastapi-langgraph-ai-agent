OPENAI_API_KEY=sk-your-key-here

# Optional — model overrides
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG / ChromaDB
# CHROMA_HOST and CHROMA_PORT are injected by docker-compose for the app container.
# To run the app or indexer OUTSIDE Docker, point these at the Chroma server
# (compose exposes it on host port 8001):
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
# CHROMA_COLLECTION=products
# RAG_TOP_K=3
